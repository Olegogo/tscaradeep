HOST=0.0.0.0
PORT=3000
TELEGRAM_BOT_TOKEN=123456789:replace_with_bot_token
TELEGRAM_CHAT_ID=123456789

# local, notion, or airtable
CMS_PROVIDER=notion
PRODUCT_CACHE_TTL_SECONDS=60

# Notion CMS
NOTION_TOKEN=secret_replace_with_notion_token
NOTION_DATABASE_ID=replace_with_notion_database_id
# Optional newer Notion API source. If present, it is used instead of NOTION_DATABASE_ID.
NOTION_DATA_SOURCE_ID=

# Airtable CMS
AIRTABLE_API_KEY=pat_replace_with_airtable_token
AIRTABLE_BASE_ID=app_replace_with_base_id
AIRTABLE_TABLE_NAME=Products
AIRTABLE_VIEW=Published
